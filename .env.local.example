# MongoDB Atlas — free at mongodb.com/atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/typecraft?retryWrites=true&w=majority

# Express API
PORT=4000
CLIENT_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-secret

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Legacy NextAuth values are not used by the current Express backend.
# NEXTAUTH_SECRET=your-random-secret-change-this-in-production
# NEXTAUTH_URL=http://localhost:3000

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
