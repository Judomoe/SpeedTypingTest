# Copy this file to server/.env and fill in your values

# MongoDB connection string (MongoDB Atlas recommended)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/speedtyping?retryWrites=true&w=majority

# Secret key for signing JWTs — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string

# Port the Express server listens on
PORT=4000

# URL of the React client (used for CORS)
CLIENT_URL=http://localhost:3000
